<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StudyGuard" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorPrimaryContainer">@color/surface_dark</item>
        <item name="colorOnPrimaryContainer">@color/accent_green</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <!-- statusBarColor and navigationBarColor are intentionally omitted here.
             enableEdgeToEdge() in MainActivity handles these transparently
             so Compose window insets work correctly on all API levels. -->
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>
</resources>
